Options +FollowSymLinks
RewriteEngine On

# Force URL canonicale sans slash final (hors racine)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} .+/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Servir directement fichiers existants
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Toutes les routes applicatives passent par index.php
RewriteRule ^ index.php [QSA,L]
